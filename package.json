{
  "name": "waly-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "expo": "~56.0.12",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "pocketbase": "^0.27.0",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "admin": "npm run dev --prefix admin-portal",
    "build:web": "npx expo export --platform web --clear",
    "build:staging": "cross-env EXPO_PUBLIC_APP_ENV=staging EXPO_PUBLIC_PB_URL=https://staging-api.waly.app npx expo export --platform web",
    "build:production": "cross-env EXPO_PUBLIC_APP_ENV=production EXPO_PUBLIC_PB_URL=https://api.waly.app npx expo export --platform web"
  },
  "private": true
}
